# Supabase (project: Backoffice tables live in the shared "GoplexLaserTag" Supabase project)
SUPABASE_URL=https://avkakvoinkuseseqkigm.supabase.co
# Service role (secret) key — from Supabase dashboard > Project Settings > API. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Publishable (anon) key — used server-side only to verify employee login passwords via Supabase Auth.
SUPABASE_ANON_KEY=sb_publishable_6XrnaQmAEMgWJs3dEdk2Yw_VfiiD1R2

# RaceFacer (Goplex Brossard) — only reachable from the local site network.
RACEFACER_BASE_URL=https://racefacer.brossard.goplex.ca
RACEFACER_USERNAME=
RACEFACER_PASSWORD=

# Clover (Goplex e-karting+, Brossard) — cloud-hosted, reachable from anywhere.
# Merchant ID from clover.com/setupapp/user/merchants (NOT the numeric "MID"
# processor id in the same table — that's a different, unrelated number).
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_MERCHANT_ID=6KAXS6QR8SCG1
CLOVER_API_TOKEN=

# Veloce (restaurant POS, Goplex Brossard) — cloud-hosted, reachable from anywhere.
# Email/password of a Veloce console user — used server-side only to fetch a
# short-lived JWT (POST /users/authenticate), never exposed to the client.
VELOCE_EMAIL=
VELOCE_PASSWORD=
# Goplex Brossard's location id in Veloce (GET /locations) — not a secret.
VELOCE_LOCATION_ID=11f07a0a-9a46-7998-b79f-0242ac130015

# Optional: port for the production Node server (bun run start). Defaults to 3000.
# PORT=3000
